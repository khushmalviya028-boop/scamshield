# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=khushal@scalemetrics.ai
SMTP_PASS=your-gmail-app-password-here

# Sender name shown in email
FROM_NAME=ScamShield Automated Scanner
FROM_EMAIL=khushal@scalemetrics.ai

# Report recipients (comma-separated for multiple)
TO_EMAIL=reportphishing@apple.com

# ── Scan config ────────────────────────────────────────────────────────────────
# Delay between Play Store API calls (ms) — keep ≥1000 to avoid rate limits
SCRAPE_DELAY_MS=1500

# Max apps to detail-scrape per run (0 = unlimited)
MAX_APPS=300

# Only report apps with riskScore >= this threshold
MIN_RISK_SCORE=40

# Path to RBI DLA dataset (relative to automation/)
RBI_DATASET_PATH=../backend/data/rbi_dla_dataset.json
