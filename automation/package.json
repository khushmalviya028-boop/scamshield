{
  "name": "@scamshield/loan-app-scanner",
  "version": "1.0.0",
  "description": "Automated scanner: finds Indian cash-loan apps not on RBI DLA list and reports them",
  "main": "src/index.ts",
  "scripts": {
    "scan": "ts-node src/index.ts",
    "scan:dry": "ts-node src/index.ts --dry-run",
    "scan:no-email": "ts-node src/index.ts --no-email"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "google-play-scraper": "^10.1.3",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
