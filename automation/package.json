{
  "name": "@scamshield/ios-loan-scanner",
  "version": "2.0.0",
  "description": "Finds unregistered Indian lending apps on the iOS App Store, checks against RBI DLA list, emails report to Apple",
  "scripts": {
    "scan": "ts-node src/index.ts",
    "scan:send": "ts-node src/index.ts --send",
    "scan:quiet": "ts-node src/index.ts --no-preview --send"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
